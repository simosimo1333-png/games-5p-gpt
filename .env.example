# クライアントの公開ビルドに埋め込むWebSocket URL（本番は必ずwss://）
VITE_GAME_SERVER_URL=wss://game.example.com

# サーバーが接続を許可するクライアントURL。複数ある場合はカンマ区切り
ALLOWED_ORIGINS=https://games-5p-gpt.pages.dev
PORT=8787

# compose.production.ymlで使う、公開済みサーバーイメージ
SERVER_IMAGE=ghcr.io/simosimo1333-png/games-5p-gpt-server:latest
SERVER_PORT=8787

# 定期監視で使うHTTPS URL（末尾の /health は不要）
PRODUCTION_SERVER_URL=https://game.example.com
PRODUCTION_WEBSOCKET_URL=wss://game.example.com
